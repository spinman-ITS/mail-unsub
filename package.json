{
  "name": "unsub-outlook-addon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "certs:install": "office-addin-dev-certs install --days 365",
    "certs:verify": "office-addin-dev-certs verify",
    "server": "tsx server/index.ts",
    "dev:all": "tsx scripts/dev-all.ts",
    "start": "tsx server/index.ts",
    "manifest:prod": "tsx scripts/make-manifest.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.13.0",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/office-js": "^1.0.474",
    "@types/pg": "^8.15.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "office-addin-dev-certs": "^2.0.9",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
